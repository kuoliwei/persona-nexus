// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// 更新Prisma Client指令，每次內容有改就要執行一次：npx prisma generate
generator client {
  provider = "prisma-client-js"
  engineType = "binary"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// 建立資料庫結構指令，若資料庫結構有改就要執行：npx prisma migrate dev --name init
model User {
  id       String @id
  email    String @unique
  password String
}